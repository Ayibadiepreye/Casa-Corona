# Casa Corona — backend env template
# Copy to .env for local dev. For production (Render), set these as
# service environment variables (most are marked sync:false in render.yaml).

# ─── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── Database (Neon Postgres) ──────────────────────────────
# Pooled connection (used by app)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/casacorona?sslmode=require
# Direct (non-pooled) connection (used for migrations)
DIRECT_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/casacorona?sslmode=require

# ─── Redis (optional — chat uses in-memory fallback) ───────
REDIS_URL=redis://default:xxx@xxx.upstash.io:6379

# ─── CORS — frontend URL(s) allowed to call the API ────────
# Comma-separated for multiple (e.g. https://casacorona.ng,https://www.casacorona.ng)
CORS_ORIGIN=http://localhost:5173

# ─── JWT secrets (REQUIRED, generate random 64-char) ───────
JWT_SECRET=replace-me-with-random-64-char-secret
JWT_REFRESH_SECRET=replace-me-with-different-random-64-char-secret
# Access tokens expire after 1h; refresh after 30d (set per user profile)

# ─── Paystack (https://dashboard.paystack.com/#/settings/developers) ─
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx

# ─── Resend (https://resend.com/api-keys) ──────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=Casa Corona <hello@casacorona.ng>

# ─── Cloudinary (https://console.cloudinary.com/) ──────────
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# ─── Google OAuth (https://console.cloud.google.com/) ──────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=https://api.casacorona.ng/api/v1/auth/google/callback

# ─── VAPID push keys (generate with: npx web-push generate-vapid-keys) ─
VAPID_PUBLIC_KEY=BP...
VAPID_PRIVATE_KEY=xxx
VAPID_SUBJECT=mailto:hello@casacorona.ng

# ─── Maintenance mode (set to "true" to lock out non-admin requests) ─
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Casa Corona is undergoing maintenance. We'll be back soon.
SUPPORT_EMAIL=support@casacorona.org
